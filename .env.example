# DocketIQ Environment Variables

# Regulations.gov API Key
# Get your key at: https://open.gsa.gov/api/regulationsgov/
REGULATIONS_GOV_API_KEY=DEMO_KEY

# OpenAI API Key (optional - for live agent runs)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI Model (optional - defaults to gpt-4)
OPENAI_MODEL=gpt-4
